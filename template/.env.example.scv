# =============================================================================
# SCV template environment variables (Notifier-related).
# If your project root already has its own `.env.example`, SCV does NOT touch
# it. Copy or append the variables below into your `.env`:
#   cp .env.example.scv .env                      # when no .env exists yet
#   cat .env.example.scv >> .env                  # to append to an existing .env
# Never commit `.env`.
# =============================================================================

# --- Project identity --------------------------------------------------------
PROJECT_NAME=my-project

# --- SCV output language (v0.4+) --------------------------------------------
# /scv:help on first run asks a 4-way AskUserQuestion (English / 한국어 /
# 日本語 / Other) and stores the answer here.
# If `~/.claude/settings.json` (or project `.claude/settings.json`) already
# has a "language" key, that wins — SCV_LANG is the fallback.
# Priority: settings.json language → SCV_LANG → auto-detect from user message → English.
# Values: english, korean, japanese, spanish, french, etc. (lowercase).
# SCV_LANG=english

# --- Notifier (collab tool) --------------------------------------------------
# Supported: slack | discord
# This value decides which adapter `/scv:report` uses.
NOTIFIER_PROVIDER=slack

# --- Slack (used only when NOTIFIER_PROVIDER=slack) -------------------------
# Bot User OAuth Token (starts with xoxb-). Required scopes: chat:write, files:write, chat:write.public
SLACK_BOT_TOKEN=xoxb-REPLACE-ME

# Default channel ID (used when no per-event override is set)
SLACK_CHANNEL_ID=C0XXXXX0

# Per-event channel overrides (optional)
SLACK_CHANNEL_ID_PHASE_COMPLETE=C0XXXXX1
SLACK_CHANNEL_ID_E2E_FAILURE=C0XXXXX2
SLACK_CHANNEL_ID_DAILY_SUMMARY=C0XXXXX3
SLACK_CHANNEL_ID_ERROR_ALERT=C0XXXXX4

# --- Discord (used only when NOTIFIER_PROVIDER=discord) ---------------------
# Bot Token (Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=REPLACE-ME

# Default channel ID
DISCORD_CHANNEL_ID=0000000000000000000

# Per-event channel overrides (optional)
DISCORD_CHANNEL_ID_PHASE_COMPLETE=
DISCORD_CHANNEL_ID_E2E_FAILURE=
DISCORD_CHANNEL_ID_DAILY_SUMMARY=
DISCORD_CHANNEL_ID_ERROR_ALERT=

# --- Send behavior -----------------------------------------------------------
# When 1, no real API call is made — payload is printed to stdout (dry-run / CI).
NOTIFIER_DRY_RUN=0

# Retry count on send failure (exponential backoff).
NOTIFIER_RETRY_MAX=3

# --- PR attachments (v0.3+) --------------------------------------------------
# Where /scv:work Step 9d uploads videos (.webm/.mp4) when creating a PR.
# 'git-orphan' (default): pushes to the scv-attachments orphan branch and
#                         embeds raw URLs in the PR body.
# 's3' / 'r2' (planned): currently fall back to git-orphan with a warning.
SCV_ATTACHMENTS_BACKEND=git-orphan

# How many days to retain after PR merge before auto-cleanup (on the orphan
# branch). Default 3. Set to 'never' for permanent retention. /scv:work Step 9d
# auto-asks (3 / 7 / 30 / Never) on first call and writes the answer here.
SCV_ATTACHMENTS_RETENTION_DAYS=3

# Orphan branch name (default: scv-attachments). Change if it conflicts.
# SCV_ATTACHMENTS_BRANCH=scv-attachments

# --- PR / MR auto-create platform (v0.5+) -----------------------------------
# Backend used by /scv:work Step 9d when creating the PR (or GitLab MR).
# Leave unset to auto-detect from `git remote get-url origin` host
# (github.com / gitlab.com). Set explicitly for self-hosted GitLab etc.
# Values: github | gitlab. (Bitbucket / Gitea: planned for later v0.5.x.)
# SCV_PR_PLATFORM=gitlab

# GitLab auth token (only when SCV_PR_PLATFORM=gitlab or origin is gitlab.com).
#
# **Recommended: `glab auth login` (v0.5.2+).** Stores the token in your OS
# native keyring (macOS Keychain / Linux libsecret / Windows Credential
# Manager) so nothing is plaintext in `.env`. SCV reads it automatically via
# `glab auth token`.
#
# Users without `glab` installed/authenticated can fall back to GITLAB_TOKEN
# below (NOT deprecated — kept for backwards compat). Scope: api +
# write_repository. Issued at: GitLab → User Settings → Access Tokens.
# GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Base URL for self-hosted GitLab (default: https://gitlab.com).
# GITLAB_HOST=https://gitlab.your-company.com

# --- GIF preview (ffmpeg-only, optional) ------------------------------------
# /scv:work converts PR videos (.webm) to .gif so they auto-play (silent)
# inline in the PR body. The .webm file is also linked for native-player
# playback (with audio) in a new tab.
# Without ffmpeg → graceful degrade: only the .webm link is attached.
# All values below are optional — leave the comments to use the defaults.
# SCV_GIF_WIDTH=480                # GIF width in px (-1 keeps original)
# SCV_GIF_FPS=10                   # frame rate
# SCV_GIF_MAX_SECONDS=60           # length cap (seconds); excess is trimmed

# --- Fast-path threshold (v0.5.1+) ------------------------------------------
# Maximum changed-line count that scv/PROMOTE.md §1.6 fast-path (direct PR
# without a promote folder) allows. Single-function/block + the other 4
# criteria + ≤ this value → fast-path OK. Default 5.
# Conservative teams: 3. Mature codebases: 10. Lock per-team via .env.
# The single-function/block rule is NOT overridable — multi-function changes
# always take the formal promote loop regardless of line count.
# SCV_FAST_PATH_LINE_THRESHOLD=5

# --- attachments_status cache (v0.3.1+) -------------------------------------
# `/scv:status` calls gh per manifest entry to compute the exact stale count.
# That's cached in /tmp with a short TTL (key: orphan branch HEAD SHA +
# retention; auto-invalidated on push). Default 300 seconds (5 min).
# Non-negative integer only. Set to 1 in CI when fresh data is required.
# SCV_STATUS_CACHE_TTL=300
