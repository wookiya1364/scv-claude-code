# =============================================================================
# SCV 템플릿 환경 변수 (Notifier 관련).
# 루트에 본인 프로젝트의 `.env.example` 이 이미 있어도 **건드리지 않습니다**.
# 이 파일의 변수들을 본인 `.env` 에 복사하거나 append 해서 쓰세요:
#   cp .env.example.scv .env                      # .env 가 없을 때
#   cat .env.example.scv >> .env                  # 기존 .env 에 덧붙일 때
# `.env` 는 절대 커밋 금지.
# =============================================================================

# --- 프로젝트 식별 -----------------------------------------------------------
PROJECT_NAME=my-project

# --- Notifier (협업툴) -------------------------------------------------------
# 지원: slack | discord
# 이 값이 /scv:report 가 어느 어댑터를 쓸지 결정합니다.
NOTIFIER_PROVIDER=slack

# --- Slack (NOTIFIER_PROVIDER=slack 일 때만 사용) ---------------------------
# Bot User OAuth Token (xoxb-로 시작). 필수 스코프: chat:write, files:write, chat:write.public
SLACK_BOT_TOKEN=xoxb-REPLACE-ME

# 기본 채널 ID (이벤트별 오버라이드가 없을 때 사용)
SLACK_CHANNEL_ID=C0XXXXX0

# 이벤트별 채널 오버라이드 (선택)
SLACK_CHANNEL_ID_PHASE_COMPLETE=C0XXXXX1
SLACK_CHANNEL_ID_E2E_FAILURE=C0XXXXX2
SLACK_CHANNEL_ID_DAILY_SUMMARY=C0XXXXX3
SLACK_CHANNEL_ID_ERROR_ALERT=C0XXXXX4

# --- Discord (NOTIFIER_PROVIDER=discord 일 때만 사용) -----------------------
# Bot Token (Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=REPLACE-ME

# 기본 채널 ID
DISCORD_CHANNEL_ID=0000000000000000000

# 이벤트별 채널 오버라이드 (선택)
DISCORD_CHANNEL_ID_PHASE_COMPLETE=
DISCORD_CHANNEL_ID_E2E_FAILURE=
DISCORD_CHANNEL_ID_DAILY_SUMMARY=
DISCORD_CHANNEL_ID_ERROR_ALERT=

# --- 전송 동작 ---------------------------------------------------------------
# 1이면 실제 API 호출 없이 payload 만 stdout에 출력 (드라이런/CI)
NOTIFIER_DRY_RUN=0

# 전송 실패 시 재시도 횟수 (지수 백오프)
NOTIFIER_RETRY_MAX=3

# --- PR 첨부 (v0.3+) ---------------------------------------------------------
# /scv:work Step 9d 가 PR 생성 시 비디오 (.webm/.mp4) 를 어디에 저장할지.
# 'git-orphan' (기본): scv-attachments orphan 브랜치에 push, raw URL 임베드
# 's3' / 'r2' (v0.4 예정 — 현재는 git-orphan 으로 fallback)
SCV_ATTACHMENTS_BACKEND=git-orphan

# PR 머지 후 며칠 보관 후 자동 삭제 (orphan 브랜치에서). 기본 3.
# 'never' 면 영구 보존. /scv:work Step 9d 가 처음 호출될 때 SCV 가 자동으로
# 묻고 이 값을 추가합니다 (3 / 7 / 30 / Never 중 선택).
SCV_ATTACHMENTS_RETENTION_DAYS=3

# Orphan 브랜치 이름 (기본: scv-attachments). 충돌 가능성 있으면 변경.
# SCV_ATTACHMENTS_BRANCH=scv-attachments

# --- GIF 미리보기 (ffmpeg 가 있을 때만 동작, 의존성은 선택) ----------------
# /scv:work 가 PR 비디오 (.webm) 를 .gif 로 동시 변환해서 PR body 에 inline
# 자동 재생 (무음). .webm 은 클릭 링크로 새 탭 native player (음성).
# ffmpeg 미설치 시 graceful degrade — .webm 링크만 첨부됩니다.
# 아래 값들은 모두 선택 (주석 그대로 두면 default).
# SCV_GIF_WIDTH=480                # GIF 가로 픽셀 (-1 은 원본 유지)
# SCV_GIF_FPS=10                   # 프레임레이트
# SCV_GIF_MAX_SECONDS=60           # 길이 cap (초). 이후는 잘림

# --- attachments_status 캐시 (v0.3.1+) -------------------------------------
# /scv:status 의 attachments stale 카운트는 매 호출마다 entry 별로 gh API
# 를 호출해야 정확. 그래서 /tmp 에 짧은 TTL 로 캐싱 (키: orphan HEAD SHA +
# retention. push 발생 시 자연 invalidate). 기본 300 초 (5 분).
# 0 이상 정수만 허용. CI 에서 항상 fresh 가 필요하면 1 로 두기.
# SCV_STATUS_CACHE_TTL=300
