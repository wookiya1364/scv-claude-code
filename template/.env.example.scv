# =============================================================================
# SCV 템플릿 환경 변수 (Notifier 관련).
# 루트에 본인 프로젝트의 `.env.example` 이 이미 있어도 **건드리지 않습니다**.
# 이 파일의 변수들을 본인 `.env` 에 복사하거나 append 해서 쓰세요:
#   cp .env.example.scv .env                      # .env 가 없을 때
#   cat .env.example.scv >> .env                  # 기존 .env 에 덧붙일 때
# `.env` 는 절대 커밋 금지.
# =============================================================================

# --- 프로젝트 식별 -----------------------------------------------------------
PROJECT_NAME=my-project

# --- Notifier (협업툴) -------------------------------------------------------
# 지원: slack | discord
# 이 값이 /scv:report 가 어느 어댑터를 쓸지 결정합니다.
NOTIFIER_PROVIDER=slack

# --- Slack (NOTIFIER_PROVIDER=slack 일 때만 사용) ---------------------------
# Bot User OAuth Token (xoxb-로 시작). 필수 스코프: chat:write, files:write, chat:write.public
SLACK_BOT_TOKEN=xoxb-REPLACE-ME

# 기본 채널 ID (이벤트별 오버라이드가 없을 때 사용)
SLACK_CHANNEL_ID=C0XXXXX0

# 이벤트별 채널 오버라이드 (선택)
SLACK_CHANNEL_ID_PHASE_COMPLETE=C0XXXXX1
SLACK_CHANNEL_ID_E2E_FAILURE=C0XXXXX2
SLACK_CHANNEL_ID_DAILY_SUMMARY=C0XXXXX3
SLACK_CHANNEL_ID_ERROR_ALERT=C0XXXXX4

# --- Discord (NOTIFIER_PROVIDER=discord 일 때만 사용) -----------------------
# Bot Token (Discord Developer Portal → Bot → Token)
DISCORD_BOT_TOKEN=REPLACE-ME

# 기본 채널 ID
DISCORD_CHANNEL_ID=0000000000000000000

# 이벤트별 채널 오버라이드 (선택)
DISCORD_CHANNEL_ID_PHASE_COMPLETE=
DISCORD_CHANNEL_ID_E2E_FAILURE=
DISCORD_CHANNEL_ID_DAILY_SUMMARY=
DISCORD_CHANNEL_ID_ERROR_ALERT=

# --- 전송 동작 ---------------------------------------------------------------
# 1이면 실제 API 호출 없이 payload 만 stdout에 출력 (드라이런/CI)
NOTIFIER_DRY_RUN=0

# 전송 실패 시 재시도 횟수 (지수 백오프)
NOTIFIER_RETRY_MAX=3
