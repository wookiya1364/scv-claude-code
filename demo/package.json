{
  "name": "scv-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion demo for SCV README hero (30-second walkthrough)",
  "scripts": {
    "preview": "remotion preview src/index.ts",
    "render": "remotion render src/index.ts ScvDemo out/scv-demo.mp4 --codec=h264",
    "render-gif": "remotion render src/index.ts ScvDemo out/scv-demo.gif --image-format=jpeg --every-nth-frame=2"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.300",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.300"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  }
}
